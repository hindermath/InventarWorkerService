                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Machine"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/Machine"
                }
              }
            }
          }
        }
      }
    },
    "/api/Inventar/machines/{machineName}/hardware": {
      "get": {
        "tags": [
          "Inventar"
        ],
        "parameters": [
          {
            "name": "machineName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Inventar/machines/{machineName}/software": {
      "get": {
        "tags": [
          "Inventar"
        ],
        "parameters": [
          {
            "name": "machineName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Inventar/hardware-overview": {
      "get": {
        "tags": [
          "Inventar"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Machine": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "operatingSystem": {
            "type": "string",
            "nullable": true
          },
          "lastSeen": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
