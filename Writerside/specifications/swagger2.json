{
  "openapi": "3.0.4",
  "info": {
    "title": "Inventar API",
    "description": "Eine API zur Verwaltung von Inventardaten",
    "contact": {
      "name": "Support Team",
      "email": "support@beispiel.com"
    },
    "version": "v1"
  },
  "paths": {
