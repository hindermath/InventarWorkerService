      "get": {
        "tags": [
          "Inventar"
        ],
        "parameters": [
          {
            "name": "machineName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
