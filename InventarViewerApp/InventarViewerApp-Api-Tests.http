### InventarViewerApp API Tests Configuration
# This section sets up the configuration for the InventarViewerApp API tests.
# Configuration for InventarViewerApp API Tests
# This section sets up the base URL and API path for the tests.
# It defines the server address and the specific endpoint for the Inventar API.
# The base URL is used to construct the full API endpoint for each request.
# The API path is appended to the base URL to form the complete request URL.
# This configuration is essential for ensuring that the tests can communicate with the correct server.
# It allows for easy modification of the server address or API path without changing individual test cases.
# The base URL and API path are defined as global variables for use in the test cases.
# This setup is crucial for maintaining a consistent testing environment.
# It ensures that all tests are executed against the same API endpoint.
# The configuration is designed to be flexible and easily adjustable for different environments.
###
@baseUrl = http://localhost:5000
@apiPath = /api/inventar

### GET: Retrieve all machines for test data(example server)
# SETUP test data
# This section retrieves a list of machines to use as test data for subsequent requests.
# It stores the first machine's ID and name in global variables for later use.
# This allows tests to dynamically reference existing machines without hardcoding values.
# The retrieved machine data is essential for validating the API's functionality.
# It ensures that the tests operate on real data, improving reliability and accuracy.
# The test data retrieval is performed before executing the main test cases.
# This setup step is crucial for ensuring that the tests have valid input to work with.
###
GET {{baseUrl}}{{apiPath}}/machines
Accept: application/json

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    
    client.test("Response is JSON array", function() {
        client.assert(response.contentType.mimeType === "application/json",
            "Content-Type should be application/json");
        client.assert(Array.isArray(response.body),
            "Response body should be an array");
    });
    
    client.test("Machines have required properties", function() {
        if (response.body && response.body.length > 0) {
            const machine = response.body[0];
            client.assert(machine.hasOwnProperty('id'),
                "Machine should have an 'id' property");
            client.assert(machine.hasOwnProperty('name'),
                "Machine should have a 'name' property");
        }
    });

    // Check if machines exist, then set global variables.
    client.test("Set testMachineId and testMachineName", function() {
        if (response.body && response.body.length > 0) {
            const machine = response.body[0];
            if (machine.hasOwnProperty('id')) {
                const machineId = machine.id != null ? machine.id : 1;
                client.global.set("testMachineId", machineId);
            } else {
                client.global.set("testMachineId", 1);
            }
            if (machine.hasOwnProperty('name') && machine.name != null) {
                client.global.set("testMachineName", machine.name);
            }
        } else {
            client.assert.fail("No machines found in the response");
        }
    });
%}

### GET: Retrieve a machine by ID (example server)
# This test retrieves a specific machine by its ID.
# It checks that the response status is 200 OK and that the machine ID matches the test data.
# It also verifies that the response is in JSON format.
# This test is useful for validating the API's ability to retrieve machine details by ID.
# It ensures that the API correctly returns the expected machine data when queried by ID.
# It can be used to verify that the API does not return incorrect or unexpected data.
# This test serves as a basic functionality check for the machine retrieval endpoint.
# It helps ensure that the API behaves as expected when accessing machine details.
# It is important for maintaining the integrity of the API and providing accurate information to users.
###
GET {{baseUrl}}{{apiPath}}/machines/{{testMachineId}}
Accept: application/json

> {%
    client.test("Machine found successfully", function() {
        client.assert(response.status === 200,
            "Response status should be 200 OK");
        client.assert(response.body.id == client.global.get("testMachineId"),
            "Machine ID should match the test data");
        client.assert(response.contentType.mimeType === "application/json",
            "Content-Type should be application/json");
    });
%}

### GET: Attempt to retrieve a non-existent machine by ID
# This test checks the API's response when trying to access a machine that does not exist.
# It should return a 404 Not Found status with an appropriate error message.
# This test is useful for validating error handling in the API.
# It ensures that the API correctly identifies when a requested resource is not available.
# It can be used to verify that the API does not expose sensitive information about non-existent resources.
# This test serves as a negative test case to ensure robustness of the API.
# It helps ensure that the API behaves predictably when faced with invalid requests.
# It is important for maintaining the integrity of the API and providing clear feedback to users.
###
GET {{baseUrl}}{{apiPath}}/machines/99999
Accept: application/json

> {%
    client.test("Non-existent machine returns 404", function() {
        client.assert(response.status === 404,
            "Response status should be 404 Not Found");
        client.assert(response.body.message === "Maschine nicht gefunden",
            "Error message should indicate machine not found");
        client.assert(response.contentType.mimeType === "application/json",
            "Content-Type should be application/json");
    });
%}

### GET: Retrieve all machines
# This test retrieves a list of all machines in the inventory.
# It checks that the response is a JSON array and that each machine has the required properties.
# It also verifies that the request was successful and the response is in the expected format.
# This test is useful for validating the overall machine inventory retrieval functionality.
# It can be used to ensure that the API correctly lists all machines and their basic details.
# It serves as a foundational test for the machine inventory endpoint.
###
GET {{baseUrl}}{{apiPath}}/machines
Accept: application/json

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response is JSON array", function() {
        client.assert(response.contentType.mimeType === "application/json");
        client.assert(Array.isArray(response.body));
    });

    client.test("Machines have required properties", function() {
        if (response.body.length > 0) {
            const machine = response.body[0];
            client.assert(machine.hasOwnProperty('id'));
            client.assert(machine.hasOwnProperty('name'));
        }
    });
%}
